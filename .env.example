APP_NAME="App2"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://app2.localhost
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=en

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=infra_postgres
DB_PORT=5432
DB_DATABASE=app2
DB_USERNAME=root
DB_PASSWORD=secret

# ─────────────────────────────────────────
# CACHE & SESSION
# ─────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─────────────────────────────────────────
# QUEUE
# ─────────────────────────────────────────
QUEUE_CONNECTION=redis

# ─────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=app2_redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ─────────────────────────────────────────
# MAIL
# ─────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@app2.localhost"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─────────────────────────────────────────
# BROWSERSHOT / PUPPETEER
# ─────────────────────────────────────────
BROWSERSHOT_CHROME_PATH=/usr/bin/chromium
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# ─────────────────────────────────────────
# WEB PUSH NOTIFICATION
# ─────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─────────────────────────────────────────
# GOOGLE 2FA
# ─────────────────────────────────────────
GOOGLE2FA_ENABLED=true

# ─────────────────────────────────────────
# FILESYSTEM
# ─────────────────────────────────────────
FILESYSTEM_DISK=local