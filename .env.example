APP_NAME="PCCS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=en

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DB_CONNECTION=sqlite
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=pccs
# DB_USERNAME=postgres
# DB_PASSWORD=secret

# ─────────────────────────────────────────
# CACHE & SESSION
# ─────────────────────────────────────────
# Use `array` for local dev so Cache::tags() works without Redis.
# On production/with Redis, switch to `redis`.
CACHE_STORE=array
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─────────────────────────────────────────
# QUEUE
# ─────────────────────────────────────────
QUEUE_CONNECTION=sync

# ─────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# ─────────────────────────────────────────
# MAIL
# ─────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@app2.localhost"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─────────────────────────────────────────
# PLAYWRIGHT PDF GENERATION
# ─────────────────────────────────────────
# Leave empty to use the Chromium binary managed by Playwright.
PLAYWRIGHT_CHROMIUM_PATH=

# Cache store used for print progress (must persist across requests).
PRINT_PROGRESS_CACHE_STORE=file

# ─────────────────────────────────────────
# WEB PUSH NOTIFICATION
# ─────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─────────────────────────────────────────
# GOOGLE 2FA
# ─────────────────────────────────────────
GOOGLE2FA_ENABLED=true

# ─────────────────────────────────────────
# FILESYSTEM
# ─────────────────────────────────────────
FILESYSTEM_DISK=local